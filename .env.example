# LLM (OpenAI-compatible endpoint)
API_BASE=https://your-llm-api-base/v1
API_KEY=sk-your-api-key
MODEL=your-model-name
# Optional task-specific overrides; leave blank to fall back to MODEL
QUESTION_MODEL=
EVALUATION_MODEL=
REFERENCE_ANSWER_MODEL=
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=1
EVALUATION_TIMEOUT_SECONDS=180
EVALUATION_MAX_RETRIES=0
DRILL_EVAL_BATCH_SIZE=1
DRILL_EVAL_REFERENCE_TOP_K=1
DRILL_EVAL_REFERENCE_MAX_CHARS=300
DRILL_EVAL_ANSWER_MAX_CHARS=800
DRILL_EVAL_USE_LLM_SYNTHESIS=false

# Embedding — API mode (OpenAI-compatible, e.g. SiliconFlow / OpenAI)
# Leave EMBEDDING_API_BASE empty to use local HuggingFace model instead
EMBEDDING_API_BASE=https://your-embedding-api-base/v1
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=BAAI/bge-m3

# Auth
DEFAULT_USER_ID=907fa4ab
DEFAULT_EMAIL=admin@techspar.local
DEFAULT_PASSWORD=admin123
ALLOW_REGISTRATION=false
